---
import "../styles/global.css";
import Nav from "../components/global/Nav.astro";
import Footer from "../components/global/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Loving Creek Farm",
  description = "A small family farm in Evington, Virginia — growing vegetables, fruit, and good things.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400&family=DM+Sans:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class="bg-cream text-bark font-sans antialiased min-h-screen flex flex-col"
  >
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
