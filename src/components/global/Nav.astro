---
const links = [
  { label: "Home", href: "/" },
  { label: "Our Farm", href: "/our-farm" },
  { label: "What We Grow", href: "/what-we-grow" },
  { label: "Updates", href: "/updates" },
  { label: "Contact", href: "/contact" },
];

const currentPath = Astro.url.pathname;

function linkClass(href: string, mobile = false) {
  const base =
    "text-sm font-medium tracking-wide transition-colors hover:text-moss";
  const active = mobile ? "text-moss" : "text-moss border-b border-moss pb-0.5";
  const inactive = "text-bark/70";
  return `${base} ${currentPath === href ? active : inactive}`;
}
---

<header
  class="sticky top-0 z-50 bg-cream/95 backdrop-blur-sm border-b border-stone-warm"
>
  <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a
      href="/"
      class="font-serif text-xl text-bark hover:text-moss transition-colors"
    >
      Loving Creek Farm
    </a>

    <ul class="hidden md:flex items-center gap-8">
      {
        links.map((link) => (
          <li>
            <a href={link.href} class={linkClass(link.href)}>
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <button
      id="menu-toggle"
      class="md:hidden text-bark hover:text-moss transition-colors"
      aria-label="Toggle menu"
    >
      <svg
        id="icon-open"
        xmlns="http://www.w3.org/2000/svg"
        class="w-6 h-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.5"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
      <svg
        id="icon-close"
        xmlns="http://www.w3.org/2000/svg"
        class="w-6 h-6 hidden"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.5"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </nav>

  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-stone-warm bg-cream"
  >
    <ul class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-4">
      {
        links.map((link) => (
          <li>
            <a href={link.href} class={linkClass(link.href, true)}>
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("icon-open");
  const iconClose = document.getElementById("icon-close");

  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
    iconOpen?.classList.toggle("hidden");
    iconClose?.classList.toggle("hidden");
  });
</script>
