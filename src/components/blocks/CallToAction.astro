---
interface Props {
  eyebrow?: string;
  heading: string;
  body?: string;
  primaryCta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}

const { eyebrow, heading, body, primaryCta, secondaryCta } = Astro.props;
---

<section class="bg-moss text-cream">
  <div
    class="max-w-3xl mx-auto px-6 py-20 text-center flex flex-col items-center gap-6"
  >
    {
      eyebrow && (
        <span class="text-xs uppercase tracking-widest text-cream/50 font-medium">
          {eyebrow}
        </span>
      )
    }
    <h2 class="font-serif text-4xl md:text-5xl leading-snug">
      {heading}
    </h2>
    {
      body && (
        <p class="text-cream/70 text-lg leading-relaxed max-w-xl">{body}</p>
      )
    }
    <div class="flex flex-col sm:flex-row gap-4 mt-2">
      <a
        href={primaryCta.href}
        class="text-sm font-medium text-moss bg-cream rounded-lg px-6 py-3 hover:bg-stone-warm
      transition-colors"
      >
        {primaryCta.label}
      </a>
      {
        secondaryCta && (
          <a
            href={secondaryCta.href}
            class="text-sm font-medium text-cream border border-cream/30 rounded-lg px-6 py-3 hover:bg-cream/10 transition-colors"
          >
            {secondaryCta.label}
          </a>
        )
      }
    </div>
  </div>
</section>
