---
interface Props {
  image: string;
  imageAlt: string;
  height?: "sm" | "md" | "lg";
}

const { image, imageAlt, height = "md" } = Astro.props;

const heightClass = {
  sm: "h-48 md:h-64",
  md: "h-64 md:h-96",
  lg: "h-96 md:h-[32rem]",
}[height];
---

<div class={`w-full overflow-hidden ${heightClass}`}>
  <img
    src={image}
    alt={imageAlt}
    class="w-full h-full object-cover object-bottom"
  />
</div>
