---

---

<div class="flex flex-col gap-6">
  <div>
    <h3 class="font-serif text-xl text-bark mb-2">Send us a message</h3>
    <p class="text-bark/70 text-sm leading-relaxed">
      We aim to respond within one to two business days.
    </p>
  </div>

  <form class="flex flex-col gap-4">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="flex flex-col gap-1.5">
        <label
          for="name"
          class="text-xs uppercase tracking-widest text-bark/50 font-medium"
        >
          Name <span class="text-harvest">*</span>
        </label>
        <input
          type="text"
          id="name"
          name="name"
          required
          placeholder="Your name"
          class="bg-white border border-stone-warm rounded-lg px-4 py-2.5 text-sm text-bark placeholder:text-bark/30 focus:outline-none focus:border-moss transition-colors"
        />
      </div>
      <div class="flex flex-col gap-1.5">
        <label
          for="email"
          class="text-xs uppercase tracking-widest text-bark/50 font-medium"
        >
          Email <span class="text-harvest">*</span>
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          placeholder="your@email.com"
          class="bg-white border border-stone-warm rounded-lg px-4 py-2.5 text-sm text-bark placeholder:text-bark/30 focus:outline-none focus:border-moss transition-colors"
        />
      </div>
    </div>

    <div class="flex flex-col gap-1.5">
      <label
        for="phone"
        class="text-xs uppercase tracking-widest text-bark/50 font-medium"
      >
        Phone
      </label>
      <input
        type="tel"
        id="phone"
        name="phone"
        placeholder="(434) 555-0123"
        class="bg-white border border-stone-warm rounded-lg px-4 py-2.5 text-sm text-bark placeholder:text-bark/30 focus:outline-none focus:border-moss transition-colors"
      />
    </div>

    <div class="flex flex-col gap-1.5">
      <label
        for="subject"
        class="text-xs uppercase tracking-widest text-bark/50 font-medium"
      >
        Subject <span class="text-harvest">*</span>
      </label>
      <input
        type="text"
        id="subject"
        name="subject"
        required
        placeholder="What's on your mind?"
        class="bg-white border border-stone-warm rounded-lg px-4 py-2.5 text-sm text-bark placeholder:text-bark/30 focus:outline-none focus:border-moss transition-colors"
      />
    </div>

    <div class="flex flex-col gap-1.5">
      <label
        for="message"
        class="text-xs uppercase tracking-widest text-bark/50 font-medium"
      >
        Message <span class="text-harvest">*</span>
      </label>
      <textarea
        id="message"
        name="message"
        required
        rows="5"
        placeholder="Tell us what you're looking for..."
        class="bg-white border border-stone-warm rounded-lg px-4 py-2.5 text-sm text-bark placeholder:text-bark/30 focus:outline-none focus:border-moss transition-colors resize-none"
      ></textarea>
    </div>

    <p class="text-xs text-bark/40">
      * Required fields. We'll never share your information with anyone.
    </p>

    <button
      type="submit"
      class="bg-moss text-cream text-sm font-medium rounded-lg px-6 py-3 hover:bg-moss-light transition-colors w-fit cursor-not-allowed opacity-75"
    >
      Send message — coming soon
    </button>
  </form>
</div>
