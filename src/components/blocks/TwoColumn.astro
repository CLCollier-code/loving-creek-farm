---
interface Props {
  image: string;
  imageAlt: string;
  eyebrow?: string;
  heading: string;
  body: string;
  cta?: { label: string; href: string };
  reverse?: boolean;
}

const {
  image,
  imageAlt,
  eyebrow,
  heading,
  body,
  cta,
  reverse = false,
} = Astro.props;
---

<section class="max-w-6xl mx-auto px-6 py-16">
  <div
    class:list={[
      "grid grid-cols-1 md:grid-cols-2 gap-12 items-center",
      reverse ? "md:[&>*:first-child]:order-2" : "",
    ]}
  >
    <!-- Image -->
    <div class="overflow-hidden rounded-lg">
      <img
        src={image}
        alt={imageAlt}
        class="w-full h-full object-cover aspect-[4/3] hover:scale-105 transition-transform duration-700"
      />
    </div>

    <!-- Text -->
    <div class="flex flex-col gap-5">
      {
        eyebrow && (
          <span class="text-xs uppercase tracking-widest text-harvest font-medium">
            {eyebrow}
          </span>
        )
      }
      <h2 class="font-serif text-3xl md:text-4xl text-bark leading-snug">
        {heading}
      </h2>
      <p class="text-bark/70 text-lg leading-relaxed">
        {body}
      </p>
      {
        cta && (
          <a
            href={cta.href}
            class="inline-block mt-2 text-sm font-medium text-moss border border-moss/40 rounded-lg px-5 py-2.5 hover:bg-moss/10 transition-colors w-fit"
          >
            {cta.label}
          </a>
        )
      }
    </div>
  </div>
</section>
