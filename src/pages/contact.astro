---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionIntro from "../components/blocks/SectionIntro.astro";
import ContactForm from "../components/blocks/ContactForm.astro";
import LocationInfo from "../components/blocks/LocationInfo.astro";

const mapEmbedUrl =
  "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d50431.0!2d-79.2868!3d37.1043!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x884ec0b3e4b6b6b7%3A0x1b2b3c4d5e6f7a8b!2sEvington%2C%20VA%2024550!5e0!3m2!1sen!2sus!4v1234567890!5m2!1sen!2sus";
---

<BaseLayout title="Contact | Loving Creek Farm">
  <SectionIntro
    eyebrow="Contact"
    heading="Let's get in touch."
    body="Have questions about what we grow, want to arrange a visit, or just want to say hello? We'd love to hear from you."
  />
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <ContactForm />
      <LocationInfo mapEmbedUrl={mapEmbedUrl} />
    </div>
  </div>
</BaseLayout>
